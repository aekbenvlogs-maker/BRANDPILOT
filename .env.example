# ============================================================
# PROJECT      : BRANDSCALE — AI Brand Scaling Tool
# FILE         : .env.example
# DESCRIPTION  : Environment variables template — copy to .env and fill values
# AUTHOR       : BRANDSCALE Dev Team
# WORKFLOW     : VSCode + Claude + Copilot Pro + File Engineering
# PYTHON       : 3.11.9
# LAST UPDATED : 2026-03-08
# ============================================================
# INSTRUCTIONS:
#   cp .env.example .env
#   Fill in all required values. Never commit .env to version control.
# ============================================================

# ---------------------------------------------------------------------------
# APPLICATION
# ---------------------------------------------------------------------------
APP_NAME=BRANDSCALE
APP_ENV=development          # development | staging | production
APP_DEBUG=true               # Set to false in production
APP_VERSION=1.0.0
APP_HOST=0.0.0.0
APP_PORT=8000
APP_TIMEZONE=Europe/Paris    # Default timezone for display

# ---------------------------------------------------------------------------
# SECURITY — JWT
# ---------------------------------------------------------------------------
SECRET_KEY=your-very-long-random-secret-key-here-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------------------------------------------------------------------------
# DATABASE — PostgreSQL (production)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://brandscale:password@localhost:5432/brandscale_db

# DATABASE — SQLite (development only)
DATABASE_URL_DEV=sqlite+aiosqlite:///./brandscale_dev.db

# ---------------------------------------------------------------------------
# REDIS — Queue & Cache
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=86400              # 24 hours in seconds
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ---------------------------------------------------------------------------
# AI — OpenAI-compatible API
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_MAX_TOKENS=2048
OPENAI_TEMPERATURE=0.7

# Optional: Local model via Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# Use local model as fallback if OpenAI fails
AI_FALLBACK_TO_LOCAL=false

# ---------------------------------------------------------------------------
# EMAIL — SMTP (development)
# ---------------------------------------------------------------------------
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_EMAIL=noreply@brandscale.io
SMTP_FROM_NAME=BRANDSCALE

# EMAIL — Production (Sendgrid or Mailgun)
SENDGRID_API_KEY=SG.your-sendgrid-api-key
MAILGUN_API_KEY=key-your-mailgun-api-key
MAILGUN_DOMAIN=mg.brandscale.io
EMAIL_PROVIDER=smtp    # smtp | sendgrid | mailgun

# ---------------------------------------------------------------------------
# STORAGE — S3-compatible (images, videos)
# ---------------------------------------------------------------------------
S3_BUCKET_NAME=brandscale-assets
S3_REGION=eu-west-3
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
S3_ENDPOINT_URL=                   # Leave empty for AWS, fill for MinIO/Backblaze

# ---------------------------------------------------------------------------
# ENCRYPTION — RGPD / PII at rest
# ---------------------------------------------------------------------------
FERNET_KEY=your-fernet-key-base64-encoded-here   # generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# ---------------------------------------------------------------------------
# MONITORING & OBSERVABILITY
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO                     # DEBUG | INFO | WARNING | ERROR
LOG_RETENTION_DAYS=90              # RGPD: logs purged after this many days
LOG_MAX_SIZE_MB=10                 # Log file rotation size

# Optional: Slack webhook for alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
ALERT_EMAIL=ops@brandscale.io

# ---------------------------------------------------------------------------
# CELERY FLOWER — Queue monitoring UI
# ---------------------------------------------------------------------------
FLOWER_PORT=5555
FLOWER_BASIC_AUTH=admin:your-flower-password

# ---------------------------------------------------------------------------
# CORS — Frontend origins allowed
# ---------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,https://app.brandscale.io

# ---------------------------------------------------------------------------
# FRONTEND — Next.js
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=BRANDSCALE
NEXT_PUBLIC_APP_VERSION=1.0.0

# ---------------------------------------------------------------------------
# RGPD
# ---------------------------------------------------------------------------
UNSUBSCRIBE_PROCESS_DELAY_HOURS=24    # Max delay to process unsubscribe requests
DATA_RETENTION_DAYS=730               # 2 years default data retention
